<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/secondaryProgress">
        <rotate android:fromDegrees="270.0" android:toDegrees="270.0" android:pivotX="50.0%" android:pivotY="50.0%">
            <shape android:shape="ring" android:innerRadiusRatio="6.0" android:thicknessRatio="20.0" android:useLevel="true">
                <gradient android:startColor="#ffffffff" android:endColor="#00ffffff" android:angle="0.0" android:type="sweep" android:centerColor="#88ffffff" />
            </shape>
        </rotate>
    </item>
</layer-list>
