<?xml version="1.0" encoding="utf-8"?>
<navigation android:label="support_navigation" android:id="@id/support_navigation" app:startDestination="@id/supportFragment"
  xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <fragment android:label="SupportFragment" android:name="com.ultramobile.mint.fragments.customize.SupportFragment" android:id="@id/supportFragment">
        <action android:id="@id/action_minTechBannerFragment" app:destination="@id/minTechBannerFragment" />
        <action android:id="@id/action_confirmTopUpFragment" app:destination="@id/confirmTopUpFragment">
            <argument android:name="type" app:argType="integer" />
        </action>
    </fragment>
    <fragment android:label="MinTechBannerFragment" android:name="com.ultramobile.mint.fragments.customize.MinTechBannerFragment" android:id="@id/minTechBannerFragment">
