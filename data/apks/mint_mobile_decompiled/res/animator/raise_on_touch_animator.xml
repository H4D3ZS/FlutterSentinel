<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <objectAnimator android:duration="300" android:valueTo="@dimen/edit_text_default_activated_elevation" android:propertyName="translationZ" />
    </item>
    <item android:state_selected="false">
        <objectAnimator android:duration="300" android:valueTo="@dimen/edit_text_default_deactivated_elevation" android:propertyName="translationZ" />
    </item>
</selector>
