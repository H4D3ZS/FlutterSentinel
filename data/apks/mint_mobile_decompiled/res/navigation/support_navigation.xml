            <argument android:name="type" app:argType="integer" />
        </action>
    </fragment>
    <fragment android:label="ConfirmPlanFragment" android:name="com.ultramobile.mint.fragments.customize.PurchaseFragment" android:id="@id/confirmTopUpFragment">
