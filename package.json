{
  "name": "fluttersentinel",
  "version": "1.0.0",
  "description": "Flutter Bounty Hunter - Autonomous Mobile Exploit Framework",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "fbhbot",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install && npm install --workspaces --if-present",
    "dev:mobsf": "node scripts/start-mobsf.js",
    "dev:frontend": "npm run dev -w frontend",
    "dev:fbhbot": "npm run dev:all -w fbhbot",
    "dev:backend": "npm run dev -w backend",
    "dev:all": "concurrently -n \"mobsf,frontend,fbhbot,backend\" -c \"cyan,green,yellow,magenta\" \"npm run dev:mobsf\" \"npm run dev:frontend\" \"npm run dev:fbhbot\" \"npm run dev:backend\"",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run dev:all",
    "health-check": "node scripts/health-check.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/FlutterSentinel.git"
  },
  "keywords": [
    "mobile-security",
    "penetration-testing",
    "flutter",
    "android",
    "ios",
    "mobsf"
  ],
  "author": "",
  "license": "MIT"
}