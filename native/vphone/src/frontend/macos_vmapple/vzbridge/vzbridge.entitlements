<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for VZVirtualMachine -->
    <key>com.apple.security.virtualization</key>
    <true/>
    <!-- Required for VZNATNetworkDeviceAttachment -->
    <key>com.apple.vm.networking</key>
    <true/>
    <!-- Required for hypervisor access on macOS -->
    <key>com.apple.security.hypervisor</key>
    <true/>
    <!-- Required for reading/writing to devices -->
    <key>com.apple.security.device.audio-input</key>
    <false/>
    <!-- Allow app to write files it creates (for serial log) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
    <!-- Required for sandbox compliance when accessing prepared directory -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
    <!-- Required for private vmapple (PV=3) hardware models -->
    <key>com.apple.private.virtualization</key>
    <true/>
</dict>
</plist>
