    d1 = {
        "\u0000\u00ac\u0002\n\u0002\u0018\u0002\n\u0002\u0018\u0002\n\u0002\u0018\u0002\n\u0002\u0008\u0003\n\u0002\u0018\u0002\n\u0000\n\u0002\u0010\u0002\n\u0002\u0008\u0010\n\u0002\u0010\u0008\n\u0002\u0008\u0002\n\u0002\u0010\u0011\n\u0002\u0018\u0002\n\u0002\u0008\u0002\n\u0002\u0010\u000e\n\u0002\u0008\u000f\n\u0002\u0010\u000b\n\u0002\u0008\u0006\n\u0002\u0018\u0002\n\u0002\u0018\u0002\n\u0002\u0008\t\n\u0002\u0018\u0002\n\u0002\u0008\u0008\n\u0002\u0018\u0002\n\u0002\u0008\u0003\n\u0002\u0018\u0002\n\u0002\u0018\u0002\n\u0000\n\u0002\u0018\u0002\n\u0002\u0008\u001b\n\u0002\u0018\u0002\n\u0002\u0008\u001a\n\u0002\u0018\u0002\n\u0002\u0008\u0008\n\u0002\u0018\u0002\n\u0002\u0008\n\n\u0002\u0018\u0002\n\u0002\u0008\u0006\n\u0002\u0018\u0002\n\u0002\u0008\u0004\n\u0002\u0018\u0002\n\u0002\u0008\u000b\n\u0002\u0018\u0002\n\u0002\u0008\u0006\n\u0002\u0018\u0002\n\u0002\u0008\u0002\n\u0002\u0018\u0002\n\u0002\u0008*\n\u0002\u0018\u0002\n\u0002\u0008\u0005\n\u0002\u0018\u0002\n\u0002\u00081\n\u0002\u0018\u0002\n\u0002\u0008Z\n\u0002\u0010\t\n\u0002\u0008\u0006\n\u0002\u0018\u0002\n\u0002\u0008\t\n\u0002\u0018\u0002\n\u0002\u0008R\n\u0002\u0018\u0002\n\u0002\u0008\u0003\n\u0002\u0018\u0002\n\u0002\u0008\t\n\u0002\u0018\u0002\n\u0002\u0008\u0002\n\u0002\u0018\u0002\n\u0002\u0008\u0002\n\u0002\u0018\u0002\n\u0002\u0008(\n\u0002\u0018\u0002\n\u0002\u0018\u0002\n\u0002\u0008\u001e\n\u0002\u0018\u0002\n\u0002\u0008\u001d\n\u0002\u0018\u0002\n\u0002\u0008\u000f\u0018\u0000 \u00ea\u00042\u00020\u0001:\u0002\u00ea\u0004B\u000f\u0012\u0006\u0010\u0003\u001a\u00020\u0002\u00a2\u0006\u0004\u0008\u0004\u0010\u0005J\u0015\u0010\t\u001a\u00020\u00082\u0006\u0010\u0007\u001a\u00020\u0006\u00a2\u0006\u0004\u0008\t\u0010\nJ\u000f\u0010\u000b\u001a\u00020\u0008H\u0014\u00a2\u0006\u0004\u0008\u000b\u0010\u000cJ\r\u0010\r\u001a\u00020\u0008\u00a2\u0006\u0004\u0008\r\u0010\u000cJ\r\u0010\u000e\u001a\u00020\u0008\u00a2\u0006\u0004\u0008\u000e\u0010\u000cJ\r\u0010\u000f\u001a\u00020\u0008\u00a2\u0006\u0004\u0008\u000f\u0010\u000cJ\r\u0010\u0010\u001a\u00020\u0008\u00a2\u0006\u0004\u0008\u0010\u0010\u000cJ\r\u0010\u0011\u001a\u00020\u0008\u00a2\u0006\u0004\u0008\u0011\u0010\u000cJ\r\u0010\u0012\u001a\u00020\u0008\u00a2\u0006\u0004\u0008\u0012\u0010\u000cJ\r\u0010\u0013\u001a\u00020\u0008\u00a2\u0006\u0004\u0008\u0013\u0010\u000cJ\r\u0010\u0014\u001a\u00020\u0008\u00a2\u0006\u0004\u0008\u0014\u0010\u000cJ\r\u0010\u0015\u001a\u00020\u0008\u00a2\u0006\u0004\u0008\u0015\u0010\u000cJ\r\u0010\u0016\u001a\u00020\u0008\u00a2\u0006\u0004\u0008\u0016\u0010\u000cJ\r\u0010\u0017\u001a\u00020\u0008\u00a2\u0006\u0004\u0008\u0017\u0010\u000cJ\r\u0010\u0018\u001a\u00020\u0008\u00a2\u0006\u0004\u0008\u0018\u0010\u000cJ\u000f\u0010\u001a\u001a\u0004\u0018\u00010\u0019\u00a2\u0006\u0004\u0008\u001a\u0010\u001bJ\u0015\u0010\u001e\u001a\n\u0012\u0004\u0012\u00020\u001d\u0018\u00010\u001c\u00a2\u0006\u0004\u0008\u001e\u0010\u001fJ7\u0010%\u001a\u00020\u00082\n\u0008\u0002\u0010!\u001a\u0004\u0018\u00010 2\u0008\u0010\"\u001a\u0004\u0018\u00010 2\u0008\u0010#\u001a\u0004\u0018\u00010 2\u0008\u0010$\u001a\u0004\u0018\u00010 \u00a2\u0006\u0004\u0008%\u0010&J\u0019\u0010\'\u001a\u00020\u00082\n\u0008\u0002\u0010!\u001a\u0004\u0018\u00010 \u00a2\u0006\u0004\u0008\'\u0010(J\r\u0010)\u001a\u00020\u0008\u00a2\u0006\u0004\u0008)\u0010\u000cJ\u0019\u0010*\u001a\u00020\u00082\n\u0008\u0002\u0010!\u001a\u0004\u0018\u00010 \u00a2\u0006\u0004\u0008*\u0010(J\u0019\u0010+\u001a\u00020\u00082\n\u0008\u0002\u0010!\u001a\u0004\u0018\u00010 \u00a2\u0006\u0004\u0008+\u0010(J\r\u0010,\u001a\u00020\u0008\u00a2\u0006\u0004\u0008,\u0010\u000cJ\r\u0010-\u001a\u00020\u0008\u00a2\u0006\u0004\u0008-\u0010\u000cJ\r\u0010.\u001a\u00020\u0008\u00a2\u0006\u0004\u0008.\u0010\u000cJ\r\u0010/\u001a\u00020\u0008\u00a2\u0006\u0004\u0008/\u0010\u000cJ\u0015\u00102\u001a\u00020\u00082\u0006\u00101\u001a\u000200\u00a2\u0006\u0004\u00082\u00103J\r\u00104\u001a\u00020\u0008\u00a2\u0006\u0004\u00084\u0010\u000cJ\u0015\u00105\u001a\u00020\u00082\u0006\u00101\u001a\u000200\u00a2\u0006\u0004\u00085\u00103J\r\u00106\u001a\u00020\u0008\u00a2\u0006\u0004\u00086\u0010\u000cJ4\u0010<\u001a\u00020\u00082%\u0008\u0002\u0010;\u001a\u001f\u0012\u0013\u0012\u001100\u00a2\u0006\u000c\u00088\u0012\u0008\u00089\u0012\u0004\u0008\u0008(:\u0012\u0004\u0012\u00020\u0008\u0018\u000107\u00a2\u0006\u0004\u0008<\u0010=J\r\u0010>\u001a\u00020\u0008\u00a2\u0006\u0004\u0008>\u0010\u000cJ\r\u0010?\u001a\u00020\u0008\u00a2\u0006\u0004\u0008?\u0010\u000cJ]\u0010D\u001a\u00020\u00082\u0008\u0008\u0002\u0010@\u001a\u00020 2\u0008\u0010A\u001a\u0004\u0018\u00010 2:\u0010;\u001a6\u0012\u0013\u0012\u001100\u00a2\u0006\u000c\u00088\u0012\u0008\u00089\u0012\u0004\u0008\u0008(:\u0012\u0015\u0012\u0013\u0018\u00010 \u00a2\u0006\u000c\u00088\u0012\u0008\u00089\u0012\u0004\u0008\u0008(C\u0012\u0004\u0012\u00020\u0008\u0018\u00010B\u00a2\u0006\u0004\u0008D\u0010EJ\r\u0010F\u001a\u00020\u0008\u00a2\u0006\u0004\u0008F\u0010\u000cJ\r\u0010G\u001a\u00020\u0008\u00a2\u0006\u0004\u0008G\u0010\u000cJ\r\u0010H\u001a\u00020\u0008\u00a2\u0006\u0004\u0008H\u0010\u000cJ\r\u0010I\u001a\u00020\u0008\u00a2\u0006\u0004\u0008I\u0010\u000cJ#\u0010M\u001a\u00020\u00082\u0008\u0010J\u001a\u0004\u0018\u00010 2\n\u0008\u0002\u0010L\u001a\u0004\u0018\u00010K\u00a2\u0006\u0004\u0008M\u0010NJ~\u0010T\u001a\u00020\u00082\u0008\u0008\u0002\u0010@\u001a\u00020 2\n\u0008\u0002\u0010A\u001a\u0004\u0018\u00010 2\u0008\u0010!\u001a\u0004\u0018\u00010 2O\u0010;\u001aK\u0012\u0013\u0012\u00110P\u00a2\u0006\u000c\u00088\u0012\u0008\u00089\u0012\u0004\u0008\u0008(Q\u0012\u0015\u0012\u0013\u0018\u00010 \u00a2\u0006\u000c\u00088\u0012\u0008\u00089\u0012\u0004\u0008\u0008(C\u0012\u0015\u0012\u0013\u0018\u00010R\u00a2\u0006\u000c\u00088\u0012\u0008\u00089\u0012\u0004\u0008\u0008(S\u0012\u0004\u0012\u00020\u00080O\u00a2\u0006\u0004\u0008T\u0010UJ\u0017\u0010V\u001a\u00020\u00082\u0008\u0010J\u001a\u0004\u0018\u00010 \u00a2\u0006\u0004\u0008V\u0010(J\u0015\u0010W\u001a\u00020\u00082\u0006\u0010J\u001a\u00020 \u00a2\u0006\u0004\u0008W\u0010(J\r\u0010X\u001a\u00020\u0008\u00a2\u0006\u0004\u0008X\u0010\u000cJ\r\u0010Y\u001a\u00020\u0008\u00a2\u0006\u0004\u0008Y\u0010\u000cJ\r\u0010Z\u001a\u00020\u0008\u00a2\u0006\u0004\u0008Z\u0010\u000cJ\r\u0010[\u001a\u00020\u0008\u00a2\u0006\u0004\u0008[\u0010\u000cJ\u0017\u0010]\u001a\u00020\u00082\u0008\u0008\u0002\u0010\\\u001a\u000200\u00a2\u0006\u0004\u0008]\u00103J\r\u0010^\u001a\u00020\u0008\u00a2\u0006\u0004\u0008^\u0010\u000cJ\r\u0010_\u001a\u00020\u0008\u00a2\u0006\u0004\u0008_\u0010\u000cJ\r\u0010`\u001a\u00020\u0008\u00a2\u0006\u0004\u0008`\u0010\u000cJ\r\u0010a\u001a\u00020\u0008\u00a2\u0006\u0004\u0008a\u0010\u000cJ\r\u0010b\u001a\u00020\u0008\u00a2\u0006\u0004\u0008b\u0010\u000cJ\r\u0010c\u001a\u00020\u0008\u00a2\u0006\u0004\u0008c\u0010\u000cJ\r\u0010d\u001a\u00020\u0008\u00a2\u0006\u0004\u0008d\u0010\u000cJ\u0017\u0010f\u001a\u00020\u00082\u0008\u0010e\u001a\u0004\u0018\u00010 \u00a2\u0006\u0004\u0008f\u0010(J\r\u0010g\u001a\u00020\u0008\u00a2\u0006\u0004\u0008g\u0010\u000cJ\r\u0010h\u001a\u00020\u0008\u00a2\u0006\u0004\u0008h\u0010\u000cJ\u0017\u0010j\u001a\u00020\u00082\u0008\u0010i\u001a\u0004\u0018\u00010 \u00a2\u0006\u0004\u0008j\u0010(J\u000f\u0010k\u001a\u0004\u0018\u00010 \u00a2\u0006\u0004\u0008k\u0010lJ\u0015\u0010o\u001a\u00020n2\u0006\u0010m\u001a\u00020 \u00a2\u0006\u0004\u0008o\u0010pJ\r\u0010q\u001a\u000200\u00a2\u0006\u0004\u0008q\u0010rJ\r\u0010s\u001a\u00020\u0008\u00a2\u0006\u0004\u0008s\u0010\u000cJ\r\u0010t\u001a\u00020\u0008\u00a2\u0006\u0004\u0008t\u0010\u000cJ\r\u0010u\u001a\u00020\u0008\u00a2\u0006\u0004\u0008u\u0010\u000cJ!\u0010x\u001a\u00020\u00082\u0008\u0010v\u001a\u0004\u0018\u00010\u00192\u0008\u0010w\u001a\u0004\u0018\u00010 \u00a2\u0006\u0004\u0008x\u0010yJ\u0017\u0010{\u001a\u00020 2\u0008\u0010z\u001a\u0004\u0018\u00010 \u00a2\u0006\u0004\u0008{\u0010|J\u0017\u0010~\u001a\u00020 2\u0008\u0010}\u001a\u0004\u0018\u00010 \u00a2\u0006\u0004\u0008~\u0010|J\r\u0010\u007f\u001a\u00020\u0008\u00a2\u0006\u0004\u0008\u007f\u0010\u000cJ\'\u0010\u0081\u0001\u001a\u00020\u00082\t\u0008\u0002\u0010\u0080\u0001\u001a\u0002002\n\u0008\u0002\u0010!\u001a\u0004\u0018\u00010 \u00a2\u0006\u0006\u0008\u0081\u0001\u0010\u0082\u0001J\u000f\u0010\u0083\u0001\u001a\u00020\u0008\u00a2\u0006\u0005\u0008\u0083\u0001\u0010\u000cJ\u0018\u0010\u0085\u0001\u001a\u00020\u00082\u0007\u0010\u0084\u0001\u001a\u00020 \u00a2\u0006\u0005\u0008\u0085\u0001\u0010(J\u0011\u0010\u0086\u0001\u001a\u00020\u0008H\u0002\u00a2\u0006\u0005\u0008\u0086\u0001\u0010\u000cJ\u0011\u0010\u0087\u0001\u001a\u00020\u0008H\u0002\u00a2\u0006\u0005\u0008\u0087\u0001\u0010\u000cJ\u0011\u0010\u0088\u0001\u001a\u00020\u0008H\u0002\u00a2\u0006\u0005\u0008\u0088\u0001\u0010\u000cJ\u001e\u0010\u008b\u0001\u001a\u00020\u00082\n\u0010\u008a\u0001\u001a\u0005\u0018\u00010\u0089\u0001H\u0002\u00a2\u0006\u0006\u0008\u008b\u0001\u0010\u008c\u0001J\u0011\u0010\u008d\u0001\u001a\u00020\u0008H\u0002\u00a2\u0006\u0005\u0008\u008d\u0001\u0010\u000cJ\u001b\u0010\u008e\u0001\u001a\u00020\u00082\u0008\u0008\u0002\u00101\u001a\u000200H\u0002\u00a2\u0006\u0005\u0008\u008e\u0001\u00103J\u001b\u0010\u008f\u0001\u001a\u00020\u00082\u0008\u0008\u0002\u00101\u001a\u000200H\u0002\u00a2\u0006\u0005\u0008\u008f\u0001\u00103J\u001b\u0010\u0090\u0001\u001a\u00020\u00082\u0008\u0008\u0002\u00101\u001a\u000200H\u0002\u00a2\u0006\u0005\u0008\u0090\u0001\u00103J\u001b\u0010\u0091\u0001\u001a\u00020\u00082\u0008\u0008\u0002\u00101\u001a\u000200H\u0002\u00a2\u0006\u0005\u0008\u0091\u0001\u00103J\u001c\u0010\u0094\u0001\u001a\u00020\u00082\u0008\u0010\u0093\u0001\u001a\u00030\u0092\u0001H\u0002\u00a2\u0006\u0006\u0008\u0094\u0001\u0010\u0095\u0001J\u001c\u0010\u0096\u0001\u001a\u0002002\u0008\u0010e\u001a\u0004\u0018\u00010 H\u0002\u00a2\u0006\u0006\u0008\u0096\u0001\u0010\u0097\u0001J\u001c\u0010\u0098\u0001\u001a\u0002002\u0008\u0010e\u001a\u0004\u0018\u00010 H\u0002\u00a2\u0006\u0006\u0008\u0098\u0001\u0010\u0097\u0001J\u001c\u0010\u0099\u0001\u001a\u0002002\u0008\u0010e\u001a\u0004\u0018\u00010 H\u0002\u00a2\u0006\u0006\u0008\u0099\u0001\u0010\u0097\u0001J\u001c\u0010\u009a\u0001\u001a\u0002002\u0008\u0010e\u001a\u0004\u0018\u00010 H\u0002\u00a2\u0006\u0006\u0008\u009a\u0001\u0010\u0097\u0001J\u001c\u0010\u009b\u0001\u001a\u0002002\u0008\u0010e\u001a\u0004\u0018\u00010 H\u0002\u00a2\u0006\u0006\u0008\u009b\u0001\u0010\u0097\u0001J\u0011\u0010\u009c\u0001\u001a\u00020\u0008H\u0002\u00a2\u0006\u0005\u0008\u009c\u0001\u0010\u000cJ\u001f\u0010\u009e\u0001\u001a\u0005\u0018\u00010\u009d\u00012\u0008\u0010\u008a\u0001\u001a\u00030\u0089\u0001H\u0002\u00a2\u0006\u0006\u0008\u009e\u0001\u0010\u009f\u0001J\'\u0010\u00a1\u0001\u001a\u00020\u00082\u0008\u0010!\u001a\u0004\u0018\u00010 2\t\u0010\u00a0\u0001\u001a\u0004\u0018\u00010 H\u0002\u00a2\u0006\u0006\u0008\u00a1\u0001\u0010\u00a2\u0001J\u0011\u0010\u00a3\u0001\u001a\u00020\u0008H\u0002\u00a2\u0006\u0005\u0008\u00a3\u0001\u0010\u000cR$\u0010\u008a\u0001\u001a\n\u0012\u0005\u0012\u00030\u0089\u00010\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00a5\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00a7\u0001\u0010\u00a8\u0001R$\u0010\u00ab\u0001\u001a\n\u0012\u0005\u0012\u00030\u00a9\u00010\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u008d\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00aa\u0001\u0010\u00a8\u0001R#\u0010\u00ad\u0001\u001a\t\u0012\u0004\u0012\u00020\u00190\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u0087\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00ac\u0001\u0010\u00a8\u0001R\"\u00109\u001a\t\u0012\u0004\u0012\u00020 0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u008b\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00ae\u0001\u0010\u00a8\u0001R#\u0010\u00b1\u0001\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00af\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00b0\u0001\u0010\u00a8\u0001R#\u0010\u00b4\u0001\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00b2\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00b3\u0001\u0010\u00a8\u0001R&\u0010\u00b8\u0001\u001a\u000c\u0012\u0007\u0012\u0005\u0018\u00010\u00b5\u00010\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00b6\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00b7\u0001\u0010\u00a8\u0001R#\u0010\u00bb\u0001\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00b9\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00ba\u0001\u0010\u00a8\u0001R%\u0010\u00be\u0001\u001a\u000c\u0012\u0007\u0012\u0005\u0018\u00010\u00bc\u00010\u00a4\u00018\u0006\u00a2\u0006\u000f\n\u0006\u0008\u00bd\u0001\u0010\u00a6\u0001\u001a\u0005\u0008\u0016\u0010\u00a8\u0001R,\u0010\u00c2\u0001\u001a\u0012\u0012\r\u0012\u000b\u0012\u0005\u0012\u00030\u00bf\u0001\u0018\u00010\u001c0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00c0\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00c1\u0001\u0010\u00a8\u0001R+\u0010\u00c4\u0001\u001a\u0011\u0012\u000c\u0012\n\u0012\u0004\u0012\u00020 \u0018\u00010\u001c0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u008e\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00c3\u0001\u0010\u00a8\u0001R+\u0010\u00c6\u0001\u001a\u0011\u0012\u000c\u0012\n\u0012\u0004\u0012\u00020 \u0018\u00010\u001c0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u0091\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00c5\u0001\u0010\u00a8\u0001R+\u0010\u00c9\u0001\u001a\u0011\u0012\u000c\u0012\n\u0012\u0004\u0012\u00020 \u0018\u00010\u001c0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00c7\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00c8\u0001\u0010\u00a8\u0001R%\u0010\u00cb\u0001\u001a\u000b\u0012\u0006\u0012\u0004\u0018\u00010 0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u0090\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00ca\u0001\u0010\u00a8\u0001R#\u0010\u00ce\u0001\u001a\t\u0012\u0004\u0012\u00020 0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00cc\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00cd\u0001\u0010\u00a8\u0001R#\u0010\u00d0\u0001\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u008f\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00cf\u0001\u0010\u00a8\u0001R#\u0010\u00d3\u0001\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00d1\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00d2\u0001\u0010\u00a8\u0001R#\u0010\u00d5\u0001\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u009e\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00d4\u0001\u0010\u00a8\u0001R#\u0010\u00d7\u0001\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00a1\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00d6\u0001\u0010\u00a8\u0001R#\u0010\u00da\u0001\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00d8\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00d9\u0001\u0010\u00a8\u0001R$\u0010e\u001a\u000b\u0012\u0006\u0012\u0004\u0018\u00010 0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00db\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00dc\u0001\u0010\u00a8\u0001R#\u0010\u00df\u0001\u001a\t\u0012\u0004\u0012\u00020 0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00dd\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00de\u0001\u0010\u00a8\u0001R$\u0010i\u001a\u000b\u0012\u0006\u0012\u0004\u0018\u00010 0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00e0\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00e1\u0001\u0010\u00a8\u0001R#\u0010\u00e3\u0001\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00e2\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00e3\u0001\u0010\u00a8\u0001R#\u0010\u00e5\u0001\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00e4\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00e5\u0001\u0010\u00a8\u0001R#\u0010\u00e7\u0001\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00e6\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00e7\u0001\u0010\u00a8\u0001R#\u0010\u00e9\u0001\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00e8\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00e9\u0001\u0010\u00a8\u0001R3\u0010\u00ef\u0001\u001a\u000c\u0012\u0007\u0012\u0005\u0018\u00010\u00ea\u00010\u00a4\u00018\u0006@\u0006X\u0086\u000e\u00a2\u0006\u0018\n\u0006\u0008\u00eb\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00ec\u0001\u0010\u00a8\u0001\"\u0006\u0008\u00ed\u0001\u0010\u00ee\u0001R$\u0010\u00f3\u0001\u001a\n\u0012\u0005\u0012\u00030\u00f0\u00010\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00f1\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00f2\u0001\u0010\u00a8\u0001R#\u0010\u00f6\u0001\u001a\t\u0012\u0004\u0012\u00020 0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00f4\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00f5\u0001\u0010\u00a8\u0001R#\u0010\u00f9\u0001\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00f7\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00f8\u0001\u0010\u00a8\u0001R#\u0010\u00fc\u0001\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00fa\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00fb\u0001\u0010\u00a8\u0001R%\u0010\u00ff\u0001\u001a\u000b\u0012\u0006\u0012\u0004\u0018\u00010 0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00fd\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00fe\u0001\u0010\u00a8\u0001R%\u0010\u0082\u0002\u001a\u000b\u0012\u0006\u0012\u0004\u0018\u0001000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u0080\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u0081\u0002\u0010\u00a8\u0001R%\u0010\u0085\u0002\u001a\u000b\u0012\u0006\u0012\u0004\u0018\u0001000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u0083\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u0084\u0002\u0010\u00a8\u0001R#\u0010\u0087\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u0088\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u0086\u0002\u0010\u00a8\u0001R#\u0010\u008a\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u0088\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u0089\u0002\u0010\u00a8\u0001R#\u0010\u008d\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u008b\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u008c\u0002\u0010\u00a8\u0001R#\u0010\u0090\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u008e\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u008f\u0002\u0010\u00a8\u0001R#\u0010\u0093\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u0091\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u0092\u0002\u0010\u00a8\u0001R#\u0010\u0096\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u0094\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u0095\u0002\u0010\u00a8\u0001R#\u0010\u0099\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u0097\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u0098\u0002\u0010\u00a8\u0001R\'\u0010\u009e\u0002\u001a\u0002008\u0006@\u0006X\u0086\u000e\u00a2\u0006\u0016\n\u0006\u0008\u009a\u0002\u0010\u009b\u0002\u001a\u0005\u0008\u009c\u0002\u0010r\"\u0005\u0008\u009d\u0002\u00103R#\u0010\u00a1\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u009f\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u00a0\u0002\u0010\u00a8\u0001R%\u0010\u00a4\u0002\u001a\u000c\u0012\u0007\u0012\u0005\u0018\u00010\u00a2\u00020\u00a4\u00018\u0006\u00a2\u0006\u000f\n\u0006\u0008\u00a3\u0002\u0010\u00a6\u0001\u001a\u0005\u0008\u000f\u0010\u00a8\u0001R%\u0010\u00a6\u0002\u001a\u000b\u0012\u0006\u0012\u0004\u0018\u0001000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00a5\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u00a6\u0002\u0010\u00a8\u0001R%\u0010\u00a8\u0002\u001a\u000b\u0012\u0006\u0012\u0004\u0018\u0001000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00a7\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u00a8\u0002\u0010\u00a8\u0001R$\u0010\u00aa\u0002\u001a\n\u0012\u0005\u0012\u00030\u00f0\u00010\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u0086\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00a9\u0002\u0010\u00a8\u0001R$\u0010\u00ad\u0002\u001a\n\u0012\u0005\u0012\u00030\u00f0\u00010\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00ab\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u00ac\u0002\u0010\u00a8\u0001R#\u0010\u00b0\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00ae\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u00af\u0002\u0010\u00a8\u0001R#\u0010\u00b3\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00b1\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u00b2\u0002\u0010\u00a8\u0001R#\u0010\u00b6\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00b4\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u00b5\u0002\u0010\u00a8\u0001R#\u0010\u00b8\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00b7\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u00b8\u0002\u0010\u00a8\u0001R0\u0010\u00bc\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006@\u0006X\u0086\u000e\u00a2\u0006\u0018\n\u0006\u0008\u00b9\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u00ba\u0002\u0010\u00a8\u0001\"\u0006\u0008\u00bb\u0002\u0010\u00ee\u0001R0\u0010\u00c0\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006@\u0006X\u0086\u000e\u00a2\u0006\u0018\n\u0006\u0008\u00bd\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u00be\u0002\u0010\u00a8\u0001\"\u0006\u0008\u00bf\u0002\u0010\u00ee\u0001R0\u0010\u00c4\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006@\u0006X\u0086\u000e\u00a2\u0006\u0018\n\u0006\u0008\u00c1\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u00c2\u0002\u0010\u00a8\u0001\"\u0006\u0008\u00c3\u0002\u0010\u00ee\u0001R0\u0010\u00c8\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006@\u0006X\u0086\u000e\u00a2\u0006\u0018\n\u0006\u0008\u00c5\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u00c6\u0002\u0010\u00a8\u0001\"\u0006\u0008\u00c7\u0002\u0010\u00ee\u0001R0\u0010\u00cb\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006@\u0006X\u0086\u000e\u00a2\u0006\u0018\n\u0006\u0008\u0094\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00c9\u0002\u0010\u00a8\u0001\"\u0006\u0008\u00ca\u0002\u0010\u00ee\u0001R0\u0010\u00cf\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006@\u0006X\u0086\u000e\u00a2\u0006\u0018\n\u0006\u0008\u00cc\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u00cd\u0002\u0010\u00a8\u0001\"\u0006\u0008\u00ce\u0002\u0010\u00ee\u0001R0\u0010\u00d3\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006@\u0006X\u0086\u000e\u00a2\u0006\u0018\n\u0006\u0008\u00d0\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u00d1\u0002\u0010\u00a8\u0001\"\u0006\u0008\u00d2\u0002\u0010\u00ee\u0001R0\u0010\u00d7\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006@\u0006X\u0086\u000e\u00a2\u0006\u0018\n\u0006\u0008\u00d4\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u00d5\u0002\u0010\u00a8\u0001\"\u0006\u0008\u00d6\u0002\u0010\u00ee\u0001R0\u0010\u00db\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006@\u0006X\u0086\u000e\u00a2\u0006\u0018\n\u0006\u0008\u00d8\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u00d9\u0002\u0010\u00a8\u0001\"\u0006\u0008\u00da\u0002\u0010\u00ee\u0001R0\u0010\u00df\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006@\u0006X\u0086\u000e\u00a2\u0006\u0018\n\u0006\u0008\u00dc\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u00dd\u0002\u0010\u00a8\u0001\"\u0006\u0008\u00de\u0002\u0010\u00ee\u0001R0\u0010\u00e3\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006@\u0006X\u0086\u000e\u00a2\u0006\u0018\n\u0006\u0008\u00e0\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u00e1\u0002\u0010\u00a8\u0001\"\u0006\u0008\u00e2\u0002\u0010\u00ee\u0001R0\u0010\u00e6\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006@\u0006X\u0086\u000e\u00a2\u0006\u0018\n\u0006\u0008\u00a3\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00e4\u0002\u0010\u00a8\u0001\"\u0006\u0008\u00e5\u0002\u0010\u00ee\u0001R0\u0010\u00ea\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006@\u0006X\u0086\u000e\u00a2\u0006\u0018\n\u0006\u0008\u00e7\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u00e8\u0002\u0010\u00a8\u0001\"\u0006\u0008\u00e9\u0002\u0010\u00ee\u0001R0\u0010\u00ee\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006@\u0006X\u0086\u000e\u00a2\u0006\u0018\n\u0006\u0008\u00eb\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u00ec\u0002\u0010\u00a8\u0001\"\u0006\u0008\u00ed\u0002\u0010\u00ee\u0001R0\u0010\u00f2\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006@\u0006X\u0086\u000e\u00a2\u0006\u0018\n\u0006\u0008\u00ef\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u00f0\u0002\u0010\u00a8\u0001\"\u0006\u0008\u00f1\u0002\u0010\u00ee\u0001R0\u0010\u00f6\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006@\u0006X\u0086\u000e\u00a2\u0006\u0018\n\u0006\u0008\u00f3\u0002\u0010\u00a6\u0001\u001a\u0006\u0008\u00f4\u0002\u0010\u00a8\u0001\"\u0006\u0008\u00f5\u0002\u0010\u00ee\u0001R3\u0010\u00f9\u0002\u001a\u000c\u0012\u0007\u0012\u0005\u0018\u00010\u009d\u00010\u00a4\u00018\u0006@\u0006X\u0086\u000e\u00a2\u0006\u0018\n\u0006\u0008\u0098\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00f7\u0002\u0010\u00a8\u0001\"\u0006\u0008\u00f8\u0002\u0010\u00ee\u0001R\u001c\u0010\u00fb\u0002\u001a\u0005\u0018\u00010\u009d\u00018\u0002@\u0002X\u0082\u000e\u00a2\u0006\u0008\n\u0006\u0008\u0096\u0001\u0010\u00fa\u0002R#\u0010\u00fc\u0002\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u009b\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00fc\u0002\u0010\u00a8\u0001R&\u0010\u00ff\u0002\u001a\u000c\u0012\u0007\u0012\u0005\u0018\u00010\u00fd\u00020\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u009a\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u00fe\u0002\u0010\u00a8\u0001R%\u0010\u0081\u0003\u001a\u000b\u0012\u0006\u0012\u0004\u0018\u00010 0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u0099\u0001\u0010\u00a6\u0001\u001a\u0006\u0008\u0080\u0003\u0010\u00a8\u0001R#\u0010\u0083\u0003\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u0082\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u0083\u0003\u0010\u00a8\u0001R,\u0010\u008b\u0003\u001a\u0005\u0018\u00010\u0084\u00038\u0006@\u0006X\u0086\u000e\u00a2\u0006\u0018\n\u0006\u0008\u0085\u0003\u0010\u0086\u0003\u001a\u0006\u0008\u0087\u0003\u0010\u0088\u0003\"\u0006\u0008\u0089\u0003\u0010\u008a\u0003R#\u0010\u008d\u0003\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u008c\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u008d\u0003\u0010\u00a8\u0001R&\u0010\u0091\u0003\u001a\u000c\u0012\u0007\u0012\u0005\u0018\u00010\u008e\u00030\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u008f\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u0090\u0003\u0010\u00a8\u0001R%\u0010\u0094\u0003\u001a\u000b\u0012\u0006\u0012\u0004\u0018\u0001000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u0092\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u0093\u0003\u0010\u00a8\u0001R$\u0010\u0097\u0003\u001a\n\u0012\u0005\u0012\u00030\u00f0\u00010\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u0095\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u0096\u0003\u0010\u00a8\u0001R#\u0010\u0099\u0003\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u0098\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u0099\u0003\u0010\u00a8\u0001R$\u0010\u009c\u0003\u001a\n\u0012\u0005\u0012\u00030\u00f0\u00010\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u009a\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u009b\u0003\u0010\u00a8\u0001R$\u0010\u009f\u0003\u001a\n\u0012\u0005\u0012\u00030\u00f0\u00010\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u009d\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u009e\u0003\u0010\u00a8\u0001R%\u0010\u00a2\u0003\u001a\u000b\u0012\u0006\u0012\u0004\u0018\u00010 0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00a0\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00a1\u0003\u0010\u00a8\u0001R%\u0010\u00a5\u0003\u001a\u000b\u0012\u0006\u0012\u0004\u0018\u00010 0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00a3\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00a4\u0003\u0010\u00a8\u0001R$\u0010\u00a8\u0003\u001a\n\u0012\u0005\u0012\u00030\u00f0\u00010\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00a6\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00a7\u0003\u0010\u00a8\u0001R$\u0010\u00ab\u0003\u001a\n\u0012\u0005\u0012\u00030\u00f0\u00010\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00a9\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00aa\u0003\u0010\u00a8\u0001R#\u0010\u00ae\u0003\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00ac\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00ad\u0003\u0010\u00a8\u0001R$\u0010\u00b1\u0003\u001a\n\u0012\u0005\u0012\u00030\u00f0\u00010\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00af\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00b0\u0003\u0010\u00a8\u0001R%\u0010\u00b4\u0003\u001a\u000b\u0012\u0006\u0012\u0004\u0018\u0001000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00b2\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00b3\u0003\u0010\u00a8\u0001R%\u0010\u00b7\u0003\u001a\u000b\u0012\u0006\u0012\u0004\u0018\u0001000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00b5\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00b6\u0003\u0010\u00a8\u0001R%\u0010\u00ba\u0003\u001a\u000b\u0012\u0006\u0012\u0004\u0018\u0001000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00b8\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00b9\u0003\u0010\u00a8\u0001R#\u0010\u00bd\u0003\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00bb\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00bc\u0003\u0010\u00a8\u0001R#\u0010\u00c0\u0003\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00be\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00bf\u0003\u0010\u00a8\u0001R#\u0010\u00c3\u0003\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00c1\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00c2\u0003\u0010\u00a8\u0001R#\u0010\u00c6\u0003\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00c4\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00c5\u0003\u0010\u00a8\u0001R#\u0010\u00c9\u0003\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00c7\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00c8\u0003\u0010\u00a8\u0001R#\u0010\u00cc\u0003\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00ca\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00cb\u0003\u0010\u00a8\u0001R#\u0010\u00cf\u0003\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00cd\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00ce\u0003\u0010\u00a8\u0001R#\u0010\u00d2\u0003\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00d0\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00d1\u0003\u0010\u00a8\u0001R$\u0010\u00d5\u0003\u001a\n\u0012\u0005\u0012\u00030\u00f0\u00010\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00d3\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00d4\u0003\u0010\u00a8\u0001R$\u0010\u00d8\u0003\u001a\n\u0012\u0005\u0012\u00030\u00f0\u00010\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00d6\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00d7\u0003\u0010\u00a8\u0001R#\u0010\u00db\u0003\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00d9\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00da\u0003\u0010\u00a8\u0001R#\u0010\u00de\u0003\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00dc\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00dd\u0003\u0010\u00a8\u0001R%\u0010\u00e0\u0003\u001a\u000b\u0012\u0006\u0012\u0004\u0018\u0001000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00df\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00e0\u0003\u0010\u00a8\u0001R&\u0010\u00e4\u0003\u001a\u000c\u0012\u0007\u0012\u0005\u0018\u00010\u00e1\u00030\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00e2\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00e3\u0003\u0010\u00a8\u0001R,\u0010\u00e8\u0003\u001a\u0012\u0012\r\u0012\u000b\u0012\u0005\u0012\u00030\u00e5\u0003\u0018\u00010\u001c0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00e6\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00e7\u0003\u0010\u00a8\u0001R&\u0010\u00eb\u0003\u001a\u000c\u0012\u0007\u0012\u0005\u0018\u00010\u00e5\u00030\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00e9\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00ea\u0003\u0010\u00a8\u0001R$\u0010\u00ee\u0003\u001a\n\u0012\u0005\u0012\u00030\u00f0\u00010\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00ec\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00ed\u0003\u0010\u00a8\u0001R%\u0010\u00f1\u0003\u001a\u000c\u0012\u0007\u0012\u0005\u0018\u00010\u00ef\u00030\u00a4\u00018\u0006\u00a2\u0006\u000f\n\u0006\u0008\u00f0\u0003\u0010\u00a6\u0001\u001a\u0005\u0008^\u0010\u00a8\u0001R%\u0010\u00f4\u0003\u001a\u000c\u0012\u0007\u0012\u0005\u0018\u00010\u00f2\u00030\u00a4\u00018\u0006\u00a2\u0006\u000f\n\u0006\u0008\u00f3\u0003\u0010\u00a6\u0001\u001a\u0005\u0008_\u0010\u00a8\u0001R+\u0010\u00f7\u0003\u001a\u0012\u0012\r\u0012\u000b\u0012\u0005\u0012\u00030\u00f5\u0003\u0018\u00010\u001c0\u00a4\u00018\u0006\u00a2\u0006\u000f\n\u0006\u0008\u00f6\u0003\u0010\u00a6\u0001\u001a\u0005\u0008a\u0010\u00a8\u0001R#\u0010\u00fa\u0003\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00f8\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00f9\u0003\u0010\u00a8\u0001R%\u0010\u00fd\u0003\u001a\u000b\u0012\u0006\u0012\u0004\u0018\u00010 0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00fb\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00fc\u0003\u0010\u00a8\u0001R$\u0010\u0080\u0004\u001a\n\u0012\u0005\u0012\u00030\u00f0\u00010\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u00fe\u0003\u0010\u00a6\u0001\u001a\u0006\u0008\u00ff\u0003\u0010\u00a8\u0001R#\u0010\u0083\u0004\u001a\t\u0012\u0004\u0012\u00020\u00190\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u0081\u0004\u0010\u00a6\u0001\u001a\u0006\u0008\u0082\u0004\u0010\u00a8\u0001R+\u0010\u0086\u0004\u001a\u0011\u0012\u000c\u0012\n\u0012\u0004\u0012\u00020 \u0018\u00010\u001c0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u0084\u0004\u0010\u00a6\u0001\u001a\u0006\u0008\u0085\u0004\u0010\u00a8\u0001R%\u0010\u0089\u0004\u001a\u000b\u0012\u0006\u0012\u0004\u0018\u00010 0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u0087\u0004\u0010\u00a6\u0001\u001a\u0006\u0008\u0088\u0004\u0010\u00a8\u0001R#\u0010\u008c\u0004\u001a\t\u0012\u0004\u0012\u00020 0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u008a\u0004\u0010\u00a6\u0001\u001a\u0006\u0008\u008b\u0004\u0010\u00a8\u0001R#\u0010\u008f\u0004\u001a\t\u0012\u0004\u0012\u00020 0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u008d\u0004\u0010\u00a6\u0001\u001a\u0006\u0008\u008e\u0004\u0010\u00a8\u0001R%\u0010\u0092\u0004\u001a\u000b\u0012\u0006\u0012\u0004\u0018\u00010 0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u0090\u0004\u0010\u00a6\u0001\u001a\u0006\u0008\u0091\u0004\u0010\u00a8\u0001R#\u0010\u0094\u0004\u001a\t\u0012\u0004\u0012\u0002000\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u0093\u0004\u0010\u00a6\u0001\u001a\u0006\u0008\u0094\u0004\u0010\u00a8\u0001R#\u0010\u0097\u0004\u001a\t\u0012\u0004\u0012\u00020 0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u0095\u0004\u0010\u00a6\u0001\u001a\u0006\u0008\u0096\u0004\u0010\u00a8\u0001R#\u0010\u009a\u0004\u001a\t\u0012\u0004\u0012\u00020K0\u00a4\u00018\u0006\u00a2\u0006\u0010\n\u0006\u0008\u0098\u0004\u0010\u00a6\u0001\u001a\